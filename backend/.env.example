# ============================
# 数据库配置（MySQL via PDO）
# ============================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=im_push
DB_USER=root
DB_PASS=

# ============================
# Redis 配置
# ============================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================
# WebSocket 推送服务
# ============================
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=9502

# ============================
# HTTP API 服务
# ============================
# HTTP_HOST 默认与 WEBSOCKET_HOST 一致，可独立配置
HTTP_HOST=0.0.0.0
HTTP_PORT=9501

# ============================
# JWT 鉴权
# ============================
JWT_SECRET=please_change_this_to_a_random_secret_string
JWT_EXPIRE=7200

# ============================
# AES 加密密钥（32字节 = 64位 hex 字符串，用于验证码加密）
# 生成方式：php -r "echo bin2hex(random_bytes(32));"
# ============================
AES_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================
# 短信服务
# ============================
SMS_API_KEY=your_sms_api_key
SMS_API_URL=https://sms.example.com/send

# ============================
# 邮件服务（SMTP）
# ============================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=
# 加密方式：tls / ssl / none
MAIL_ENCRYPTION=tls
# 发件人显示名称（含空格必须用双引号包裹）
MAIL_SENDER_NAME="Push 推送服务"

# ============================
# 业务参数
# ============================
# 离线消息保留时长（秒），默认 24 小时
OFFLINE_MESSAGE_TTL=86400
# 默认心跳间隔（秒）
DEFAULT_HEARTBEAT_INTERVAL=30
