{
  "info": {
    "name": "即时消息推送系统 API",
    "_postman_id": "push-system-collection-v1",
    "description": "即时消息推送系统完整接口测试集合\n\n包含：用户认证、管理员、Key管理、设备管理、黑名单、推送、开放API、APP打包、系统设置\n\n环境变量：\n- base_url: HTTP API 地址（如 http://127.0.0.1:9501）\n- ws_url: WebSocket 地址（如 ws://127.0.0.1:9502）\n- admin_token: 管理员 JWT（登录后自动填充）\n- api_key: 开放API的 X-Api-Key（创建后自动填充）\n- user_token: 用户 JWT（登录后自动填充）",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:9501",
      "description": "HTTP API 基础地址"
    },
    {
      "key": "ws_url",
      "value": "ws://127.0.0.1:9502",
      "description": "WebSocket 推送服务地址"
    },
    {
      "key": "admin_token",
      "value": "",
      "description": "管理员 JWT Token（登录后自动填充）"
    },
    {
      "key": "api_key",
      "value": "",
      "description": "开放 API Key（创建后自动填充）"
    },
    {
      "key": "user_token",
      "value": "",
      "description": "用户 JWT Token（登录后自动填充）"
    },
    {
      "key": "captcha_token",
      "value": "",
      "description": "图形验证码 token（获取后自动填充）"
    },
    {
      "key": "captcha_code",
      "value": "",
      "description": "图形验证码明文（需人工识别）"
    },
    {
      "key": "key_id",
      "value": "",
      "description": "推送 Key ID"
    },
    {
      "key": "device_id",
      "value": "test_device_001",
      "description": "测试设备ID"
    },
    {
      "key": "build_id",
      "value": "",
      "description": "打包任务ID"
    }
  ],
  "item": [
    {
      "name": "用户认证",
      "description": "用户注册与登录流程：获取图形验证码 → 发送验证码 → 注册 → 登录",
      "item": [
        {
          "name": "获取图形验证码",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/captcha/image",
              "host": ["{{base_url}}"],
              "path": ["captcha", "image"]
            },
            "description": "获取图形验证码图片（base64）与 token\n\n返回：\n{\n  \"code\": 0,\n  \"data\": { \"token\": \"...\", \"image\": \"data:image/png;base64,...\" }\n}\n\n注意：验证码图片需人工识别后填入 captcha_code 变量"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test('状态码 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('返回 token 和 image', function () {",
                  "    pm.expect(response.data.token).to.not.be.empty;",
                  "    pm.expect(response.data.image).to.contain('data:image/png;base64');",
                  "});",
                  "// 自动保存 token",
                  "if (response.data && response.data.token) {",
                  "    pm.collectionVariables.set('captcha_token', response.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "发送短信验证码",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"type\": \"sms\",\n    \"target\": \"13800138000\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/send-code",
              "host": ["{{base_url}}"],
              "path": ["auth", "send-code"]
            },
            "description": "发送短信验证码\n\nBody:\n{\n  \"type\": \"sms\",\n  \"target\": \"手机号\"\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test('验证码发送成功', function () {",
                  "    pm.expect(response.code).to.eql(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "发送邮箱验证码",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"type\": \"email\",\n    \"target\": \"test@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/send-code",
              "host": ["{{base_url}}"],
              "path": ["auth", "send-code"]
            },
            "description": "发送邮箱验证码\n\nBody:\n{\n  \"type\": \"email\",\n  \"target\": \"邮箱\"\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test('验证码发送成功', function () {",
                  "    pm.expect(response.code).to.eql(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "用户注册",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"testuser\",\n    \"phone\": \"13800138000\",\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\",\n    \"code_type\": \"sms\",\n    \"code_target\": \"13800138000\",\n    \"code_input\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "用户注册\n\nBody:\n{\n  \"username\": \"用户名\",\n  \"phone\": \"手机号\",\n  \"email\": \"邮箱\",\n  \"password\": \"密码\",\n  \"code_type\": \"sms|email\",\n  \"code_target\": \"验证码发送目标\",\n  \"code_input\": \"用户输入的验证码\"\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test('注册成功', function () {",
                  "    pm.expect(response.code).to.eql(0);",
                  "    pm.expect(response.data.user_id).to.be.above(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "用户登录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"account\": \"testuser\",\n    \"password\": \"password123\",\n    \"captcha_token\": \"{{captcha_token}}\",\n    \"captcha_input\": \"{{captcha_code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "用户登录（支持用户名/手机号/邮箱）\n\nBody:\n{\n  \"account\": \"账号\",\n  \"password\": \"密码\",\n  \"captcha_token\": \"图形验证码token\",\n  \"captcha_input\": \"图形验证码\"\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test('登录成功', function () {",
                  "    pm.expect(response.code).to.eql(0);",
                  "    pm.expect(response.data.token).to.not.be.empty;",
                  "});",
                  "// 自动保存用户 token",
                  "if (response.data && response.data.token) {",
                  "    pm.collectionVariables.set('user_token', response.data.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "管理员管理",
      "description": "管理员登录及账号管理",
      "item": [
        {
          "name": "管理员登录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\",\n    \"captcha_token\": \"{{captcha_token}}\",\n    \"captcha_input\": \"{{captcha_code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/login",
              "host": ["{{base_url}}"],
              "path": ["admin", "login"]
            },
            "description": "管理员登录，签发带 role 的 JWT\n\n默认账号：admin / admin123\n\n注意：需先调用「获取图形验证码」获取 token，并手动识别验证码填入 captcha_code"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test('管理员登录成功', function () {",
                  "    pm.expect(response.code).to.eql(0);",
                  "    pm.expect(response.data.token).to.not.be.empty;",
                  "    pm.expect(response.data.admin.role).to.eql('super_admin');",
                  "});",
                  "// 自动保存管理员 token",
                  "if (response.data && response.data.token) {",
                  "    pm.collectionVariables.set('admin_token', response.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "获取当前管理员信息",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/info",
              "host": ["{{base_url}}"],
              "path": ["admin", "info"]
            },
            "description": "获取当前登录管理员信息"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
