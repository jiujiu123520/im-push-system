              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"target_type\": \"device\",\n    \"target_value\": \"{{device_id}}\",\n    \"title\": \"开放API单设备推送\",\n    \"content\": \"通过X-Api-Key鉴权的推送\",\n    \"payload\": {\n        \"key\": \"value\"\n    },\n    \"priority\": \"high\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/push",
