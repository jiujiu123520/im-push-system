            "description": "开放 API 推送 - 单设备\n\n鉴权：X-Api-Key 请求头\n\nBody:\n{\n  \"target_type\": \"device|key\",\n  \"target_value\": \"设备ID或Key值（多个逗号分隔）\",\n  \"title\": \"标题\",\n  \"content\": \"内容\",\n  \"payload\": {},\n  \"priority\": \"high|normal|low\"\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test('开放API推送成功', function () {",
                  "    pm.expect(response.code).to.eql(0);",
                  "    pm.expect(response.data).to.have.property('success_count');",
                  "    pm.expect(response.data).to.have.property('fail_count');",
                  "});"
                ]
              }
            }
