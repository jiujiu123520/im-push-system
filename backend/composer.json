{
    "name": "app/im-push-backend",
    "description": "基于 PHP + Swoole 的即时消息推送系统后端",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "ext-swoole": ">=4.5",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-gd": "*",
        "firebase/php-jwt": "^6.0",
        "predis/predis": "^2.0",
        "vlucas/phpdotenv": "^5.4",
        "intervention/image": "^2.7",
        "phpmailer/phpmailer": "^6.8"
    },
    "require-dev": {
        "swoole/ide-helper": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "kylekatarnls/update-helper": true
        },
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    }
}
