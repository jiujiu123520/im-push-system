[Unit]
Description=IM Push System - APP Build Worker
Documentation=https://github.com/jiujiu123520/im-push-system
After=network.target mysql.service redis-server.service
Wants=mysql.service redis-server.service
# 打包工作进程依赖 Redis 队列（与推送服务共享）
After=push-http.service
# 启动失败重试上限
StartLimitBurst=5
StartLimitIntervalSec=30

[Service]
Type=simple
# 项目根目录
WorkingDirectory=/www/push-system
# PHP 打包工作进程
ExecStart=/usr/bin/php /www/push-system/build/queue/BuildWorker.php
# 优雅停止
KillSignal=SIGTERM
TimeoutStopSec=30
# 自动重启：崩溃后 5 秒重启（打包进程可能因 Gradle 失败退出）
Restart=always
RestartSec=5
# 打包进程需要较高权限访问 Android SDK
User=www-data
Group=www-data
# 环境变量
Environment=APP_ENV=production
# Android SDK 路径（按实际安装路径调整）
Environment=ANDROID_HOME=/opt/android-sdk
Environment=ANDROID_SDK_ROOT=/opt/android-sdk
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/opt/android-sdk/cmdline-tools/latest/bin:/opt/android-sdk/platform-tools:/opt/gradle-8.7/bin

# ========= cgroup 资源限制（2H2G 服务器平衡策略）=========
# 注意：以下指令需要 systemd 227+（CentOS 7 的 systemd 219 不支持）
# install.sh 部署时会检测 systemd 版本，过低则自动移除这些指令
# 内存硬限制 1.5G（留 500MB 给 MySQL/Redis/PHP/Nginx 等系统服务）
# JVM 堆 768m + Metaspace 256m ≈ 1G，加上 native 工具（aapt2/d8）约 400MB
MemoryMax=1536M
# 内存软限制 1.2G（超过此值内核开始回收，给构建留足空间）
MemoryHigh=1200M
# CPU 限制为 1.5 核（留 0.5 核给系统服务保持响应）
CPUQuota=150%
# 最大任务数 128（足够 Gradle fork 子进程，同时防止 fork 炸弹）
TasksMax=128
# 文件描述符限制
LimitNOFILE=65536
# 进程数限制
LimitNPROC=256
# 禁止产生 core dump
LimitCORE=0

# 标准输出重定向到 journalctl
StandardOutput=journal
StandardError=journal
SyslogIdentifier=push-build-worker

[Install]
WantedBy=multi-user.target
